# ── Scoring pipeline (required) ────────────────────────────────────────────────
SOLANA_TRACKER_API_KEY=your_solana_tracker_key_here

# Legacy keys — referenced by older spike scripts, not the live scoring path.
HELIUS_API_KEY=your_helius_key_here
BIRDEYE_API_KEY=your_birdeye_key_here

# ── Cache (optional) ───────────────────────────────────────────────────────────
# Receipts, leaderboard, claim records, rate-limit counters.
# Without these the API still works, just falls back to per-instance in-memory
# (no share URLs across restarts, no global leaderboard across instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Airdrop claim (optional — feature stays hidden unless ALL of these are set) ─
# Once enabled, top-20 leaderboard wallets can claim a tiered $PEGGY airdrop.
# See the whitepaper /whitepaper#airdrop for the security model.
AIRDROP_ENABLED=
AIRDROP_TOKEN_MINT=
AIRDROP_TOKEN_DECIMALS=
AIRDROP_BASE_AMOUNT=
AIRDROP_TOKEN_SYMBOL=PEGGY
# Base58 string OR JSON byte array. NEVER commit this. Recommend a dedicated
# wallet funded only with the airdrop budget so the blast radius is bounded.
AIRDROP_SIGNER_SECRET_KEY=
# Mainnet RPC — Helius / Quicknode strongly recommended over the public endpoint.
SOLANA_RPC_URL=
