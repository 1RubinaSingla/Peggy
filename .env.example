HELIUS_API_KEY=your_helius_key_here
BIRDEYE_API_KEY=your_birdeye_key_here
SOLANA_TRACKER_API_KEY=your_solana_tracker_key_here

# Optional — receipts get cached if these are set (Upstash Redis).
# Without them, the API still works, just without persistence (no share URLs).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
